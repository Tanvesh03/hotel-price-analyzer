# Hotel Price Analyzer - Environment Variables
# Copy this to .env and fill in your values

# Database
DB_PATH=database/price_data.db

# Scraper Settings
HEADLESS=true
SCRAPE_DAYS=7
SCRAPE_HOUR=6
SCRAPE_MINUTE=0

# Parity Thresholds
VIOLATION_THRESHOLD=0.05
WARNING_THRESHOLD=0.02

# Optional: Proxy (leave blank to disable)
PROXY_URL=

# Optional: Telegram Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dashboard
DASHBOARD_PORT=8501
DASHBOARD_HOST=localhost
